{
  "expo": {
    "name": "shopping-run",
    "slug": "shopping-run",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#40146b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jpcodingboy.shoppingrun"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#40146b"
      },
      "package": "com.jpcodingboy.shoppingrun"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b9447121-e657-4dc3-b194-16322705cb71"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b9447121-e657-4dc3-b194-16322705cb71"
    }
  }
}
